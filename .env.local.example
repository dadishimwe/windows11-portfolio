# Portfolio (this site)
NEXT_PUBLIC_SITE_URL=https://dadishimwe.com

# Blog (Firefox default tab, external links)
NEXT_PUBLIC_BLOG_URL=https://blog.dadishimwe.com

NEXT_PUBLIC_GOOGLE_ANALYTICS=google-analytics-id

# Cloudinary — Pictures & Videos folders in File Explorer
# Uses Media Library folders (asset_folder), not public_id paths.
# Upload photos to portfolio/photos and videos to portfolio/videos.
CLOUDINARY_CLOUD_NAME=drw75019w
CLOUDINARY_API_KEY=your-api-key-from-cloudinary-dashboard
CLOUDINARY_API_SECRET=your-api-secret-from-cloudinary-dashboard

# Optional folder prefixes (defaults match config/cloudinary.ts)
# CLOUDINARY_IMAGE_PREFIX=portfolio/photos
# CLOUDINARY_VIDEO_PREFIX=portfolio/videos
# CLOUDINARY_RESUME_PREFIX=portfolio/resume
# CLOUDINARY_CERT_PEPLINK_PREFIX=portfolio/certifications/peplink
# CLOUDINARY_CERT_MIT_PREFIX=portfolio/certifications/mit
# CLOUDINARY_CERT_MIT_ONLINE_PREFIX=portfolio/certifications/mit-online
#
# Or use a single URL instead of the three vars above:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@drw75019w

# Mail (Resend) — https://resend.com
# Without these, Compose falls back to mailto: when sending.
RESEND_API_KEY=re_your_resend_api_key
MAIL_TO=dadi29skl@gmail.com
# Must be a verified sender in Resend (use onboarding@resend.dev for testing)
MAIL_FROM=Portfolio Contact <onboarding@resend.dev>
