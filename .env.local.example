NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

NEXT_PUBLIC_GOOGLE_ANALYTICS=google-analytics-id

# Cloudinary — Pictures & Videos folders in File Explorer
# Cloud name is public; API key + secret stay server-side only (Vercel env vars).
CLOUDINARY_CLOUD_NAME=drw75019w
CLOUDINARY_API_KEY=your-api-key-from-cloudinary-dashboard
CLOUDINARY_API_SECRET=your-api-secret-from-cloudinary-dashboard

# Optional folder prefixes (defaults match config/cloudinary.ts)
# CLOUDINARY_IMAGE_PREFIX=portfolio/photos
# CLOUDINARY_VIDEO_PREFIX=portfolio/videos
#
# Or use a single URL instead of the three vars above:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@drw75019w
